<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:G33kST.ViewModels"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:ui="clr-namespace:DTC.Core.UI;assembly=DTC.Core"
        mc:Ignorable="d"
        x:Class="G33kST.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="1066" Height="768"
        MinWidth="520" MinHeight="320"
        DragDrop.AllowDrop="True"
        Title="{Binding WindowTitle}">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style Selector="Menu">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <Style Selector="Image">
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Command="{Binding ResetMachine}" Gesture="{OnPlatform 'ctrl+r', macOS='⌘+r'}" />
        <KeyBinding Command="{Binding HardResetMachine}" Gesture="{OnPlatform 'ctrl+shift+r', macOS='⌘+shift+r'}" />
        <KeyBinding Command="{Binding SelectRomImage}" Gesture="{OnPlatform 'ctrl+shift+o', macOS='⌘+shift+o'}" />
        <KeyBinding Command="{Binding MountFloppyImage}" Gesture="{OnPlatform 'ctrl+o', macOS='⌘+o'}" />
        <KeyBinding Command="{Binding SaveScreenshotCommand}" Gesture="{OnPlatform 'ctrl+s', macOS='⌘+s'}" />
        <KeyBinding Command="{Binding ToggleRecordingCommand}" Gesture="{OnPlatform 'ctrl+m', macOS='⌘+m'}" />
        <KeyBinding Command="{Binding ToggleJoystickInput}" Gesture="{OnPlatform 'ctrl+j', macOS='⌘+j'}" />
        <KeyBinding Command="{Binding CloseCommand}" Gesture="{OnPlatform 'ctrl+q', macOS='⌘+q'}" />
    </Window.KeyBindings>

    <dialogHostAvalonia:DialogHost x:Name="Host" OverlayBackground="Black">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="Mount Floppy A..."
                              Command="{Binding MountFloppyImage}"
                              InputGesture="{OnPlatform 'ctrl+o', macOS='⌘+o'}" />
                    <MenuItem Header="Mount Recent Floppy">
                        <MenuItem Header="Empty" IsVisible="{Binding FloppyMru.IsEmpty}" IsEnabled="False" />
                        <MenuItem Header="{Binding FloppyMru.Item1}" ToolTip.Tip="{Binding FloppyMru.Item1.FullName}" IsVisible="{Binding FloppyMru.Item1.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="1" />
                        <MenuItem Header="{Binding FloppyMru.Item2}" ToolTip.Tip="{Binding FloppyMru.Item2.FullName}" IsVisible="{Binding FloppyMru.Item2.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="2" />
                        <MenuItem Header="{Binding FloppyMru.Item3}" ToolTip.Tip="{Binding FloppyMru.Item3.FullName}" IsVisible="{Binding FloppyMru.Item3.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="3" />
                        <MenuItem Header="{Binding FloppyMru.Item4}" ToolTip.Tip="{Binding FloppyMru.Item4.FullName}" IsVisible="{Binding FloppyMru.Item4.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="4" />
                        <MenuItem Header="{Binding FloppyMru.Item5}" ToolTip.Tip="{Binding FloppyMru.Item5.FullName}" IsVisible="{Binding FloppyMru.Item5.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="5" />
                        <MenuItem Header="{Binding FloppyMru.Item6}" ToolTip.Tip="{Binding FloppyMru.Item6.FullName}" IsVisible="{Binding FloppyMru.Item6.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="6" />
                        <MenuItem Header="{Binding FloppyMru.Item7}" ToolTip.Tip="{Binding FloppyMru.Item7.FullName}" IsVisible="{Binding FloppyMru.Item7.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="7" />
                        <MenuItem Header="{Binding FloppyMru.Item8}" ToolTip.Tip="{Binding FloppyMru.Item8.FullName}" IsVisible="{Binding FloppyMru.Item8.IsUsed}" Command="{Binding FloppyMru.Open}" CommandParameter="8" />
                        <Separator />
                        <MenuItem Header="Clear" Command="{Binding FloppyMru.Clear}" />
                    </MenuItem>
                    <MenuItem Header="_ROM">
                        <MenuItem Header="Select _ROM Image..."
                                  Command="{Binding SelectRomImage}"
                                  InputGesture="{OnPlatform 'ctrl+shift+o', macOS='⌘+shift+o'}" />
                        <MenuItem Header="Use Bundled EmuTOS"
                                  Command="{Binding UseBundledEmuTosRom}" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Save _Screenshot..."
                              Command="{Binding SaveScreenshotCommand}"
                              InputGesture="{OnPlatform 'ctrl+s', macOS='⌘+s'}" />
                    <MenuItem Header="Start _Recording"
                              Command="{Binding StartRecordingCommand}"
                              InputGesture="{OnPlatform 'ctrl+m', macOS='⌘+m'}"
                              IsEnabled="{Binding IsRecordingAvailable}"
                              IsVisible="{Binding !IsRecording}" />
                    <MenuItem Header="Stop _Recording..."
                              Command="{Binding StopRecordingCommand}"
                              InputGesture="{OnPlatform 'ctrl+m', macOS='⌘+m'}"
                              IsVisible="{Binding IsRecording}" />
                    <Separator />
                    <MenuItem Header="_Exit"
                              Command="{Binding CloseCommand}"
                              InputGesture="{OnPlatform 'ctrl+q', macOS='⌘+q'}" />
                </MenuItem>

                <MenuItem Header="_Emulation">
                    <MenuItem Header="_Soft Reset"
                              Command="{Binding ResetMachine}"
                              InputGesture="{OnPlatform 'ctrl+r', macOS='⌘+r'}" />
                    <MenuItem Header="_Hard Reset"
                              Command="{Binding HardResetMachine}"
                              InputGesture="{OnPlatform 'ctrl+shift+r', macOS='⌘+shift+r'}" />
                    <Separator />
                    <MenuItem Header="Input Experiments">
                        <MenuItem Header="Report Input Queue Sizes" Command="{Binding ReportInputQueueSizes}" />
                        <MenuItem Header="Clear Input Queues" Command="{Binding ClearInputQueues}" />
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="_Display">
                    <MenuItem Header="Emulate CRT" Command="{Binding ToggleCrtEmulation}">
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding Settings.IsCrtEmulationEnabled}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Ambient Blur" Command="{Binding ToggleAmbientBlur}">
                        <MenuItem.Effect>
                            <BlurEffect Radius="2" />
                        </MenuItem.Effect>
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding Settings.IsAmbientBlurred}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Show Speed Indicator" Command="{Binding ToggleSpeedIndicator}">
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding Settings.IsSpeedIndicatorVisible}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Video Timing">
                        <MenuItem Header="NTSC (60 Hz)" Command="{Binding SetNtscVideoRegion}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Tick" IsVisible="{Binding !IsPalVideoRegion}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="PAL (50 Hz)" Command="{Binding SetPalVideoRegion}">
                            <MenuItem.Icon>
                                <icons:MaterialIcon Kind="Tick" IsVisible="{Binding IsPalVideoRegion}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="High Resolution Mono" Command="{Binding ToggleDisplayResolutionMode}">
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding IsHighResolutionMode}" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="_Debug" IsVisible="{Binding IsDebugBuild}">
                    <MenuItem Header="Track CPU History" Command="{Binding TrackCpuHistory}">
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding Settings.IsCpuHistoryTracked}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Capture CPU Exceptions" Command="{Binding ToggleCpuExceptionCapture}">
                        <MenuItem.Icon>
                            <icons:MaterialIcon Kind="Tick" IsVisible="{Binding Settings.IsCpuExceptionCaptureEnabled}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Dump CPU History"
                              Command="{Binding DumpCpuHistory}"
                              IsEnabled="{Binding Settings.IsCpuHistoryTracked}" />
                    <Separator />
                    <MenuItem Header="Report CPU Clock Ticks" Command="{Binding ReportCpuClockTicks}" />
                </MenuItem>

                <MenuItem Header="_Help">
                    <MenuItem Header="_Open Project Page..." Command="{Binding OpenProjectPage}" />
                    <MenuItem Header="_Open Log..." Command="{Binding OpenLog}" />
                    <MenuItem Header="_About..."
                              Command="{Binding OpenDialogCommand, ElementName=Host}">
                        <MenuItem.CommandParameter>
                            <ui:AboutDialogContent AboutInfo="{Binding AboutInfo}" PointerPressed="OnAboutDialogClicked" />
                        </MenuItem.CommandParameter>
                    </MenuItem>
                </MenuItem>
            </Menu>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="8,0,8,0">
                <StackPanel.Styles>
                    <Style Selector="TextBlock">
                        <Setter Property="FontWeight" Value="Normal" />
                    </Style>
                </StackPanel.Styles>

                <ToggleButton IsChecked="{Binding IsJoystickInputEnabled, Mode=OneWay}"
                              Command="{Binding ToggleJoystickInput}"
                              ToolTip.Tip="Joystick input"
                              Margin="0,0,8,0">
                    <Viewbox Width="24"
                             Height="24"
                             Stretch="Uniform"
                             RenderTransformOrigin="0, 12">
                        <Viewbox.RenderTransform>
                            <ScaleTransform ScaleY="-1" />
                        </Viewbox.RenderTransform>
                        <Path Fill="White"
                              Tag="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              Data="M5250 12793 c-262 -28 -551 -122 -626 -204 l-32 -34 -21 -950 c-57 -2485 -89 -3827 -93 -3830 -2 -1 -307 -157 -678 -348 -371 -190 -1089 -557 -1595 -817 -506 -259 -938 -475 -960 -480 -123 -28 -252 -91 -329 -161 -36 -32 -137 -90 -351 -200 -330 -170 -389 -205 -454 -270 -84 -84 -110 -182 -111 -408 0 -106 18 -255 125 -1010 69 -487 139 -983 155 -1101 39 -281 45 -312 86 -397 45 -94 113 -154 274 -243 69 -37 1038 -553 2155 -1146 1513 -804 2054 -1086 2125 -1110 341 -117 777 -110 1101 16 80 32 4240 2259 4312 2309 66 46 114 101 143 165 23 50 27 76 31 175 3 70 62 532 149 1164 82 597 144 1082 144 1126 0 108 -17 233 -41 297 -26 68 -100 150 -185 204 -36 23 -1002 509 -2147 1082 -1145 572 -2084 1041 -2085 1043 -2 2 -30 1104 -62 2450 -52 2156 -61 2449 -75 2471 -79 121 -635 242 -955 207z m-787 -5780 c-2 -43 -10 -376 -18 -741 l-16 -663 27 -22 c385 -310 931 -399 1428 -233 59 20 148 56 198 82 99 49 252 149 284 186 l20 23 -18 719 c-10 396 -15 722 -13 725 12 11 302 -62 510 -129 949 -303 1545 -919 1500 -1549 -45 -639 -682 -1200 -1680 -1480 -640 -180 -1434 -215 -2125 -95 -839 145 -1530 502 -1877 969 -64 85 -146 240 -178 336 -153 449 14 922 455 1291 361 302 821 507 1455 651 50 12 50 12 48 -70z m-3678 -1306 c0 -66 5 -91 24 -130 52 -106 163 -198 315 -259 39 -16 58 -26 41 -23 -51 10 -187 82 -246 128 -57 46 -123 133 -134 180 -14 55 -28 42 -21 -19 10 -87 47 -157 119 -228 295 -289 963 -279 1235 19 64 70 94 134 99 215 l4 65 -24 -57 c-40 -94 -133 -192 -221 -234 -17 -8 -22 -9 -12 -2 135 90 204 172 232 276 14 50 15 72 7 107 -6 25 -7 45 -3 45 16 0 109 -111 131 -157 20 -39 24 -64 24 -133 0 -74 -4 -92 -30 -144 -62 -123 -252 -254 -445 -306 -244 -65 -526 -65 -770 1 -41 11 -122 42 -178 70 -86 42 -117 64 -182 127 -96 96 -124 158 -118 267 4 87 33 150 101 223 28 28 50 52 51 52 1 0 1 -37 1 -83z m1135 -372 c-14 -8 -29 -14 -35 -14 -5 0 1 6 15 14 14 8 30 14 35 14 6 0 -1 -6 -15 -14z m-60 -25 c-8 -5 -19 -10 -25 -10 -5 0 -3 5 5 10 8 5 20 10 25 10 6 0 3 -5 -5 -10z m-633 -26 c-3 -3 -12 -4 -19 -1 -8 3 -5 6 6 6 11 1 17 -2 13 -5z m40 -10 c-3 -3 -12 -4 -19 -1 -8 3 -5 6 6 6 11 1 17 -2 13 -5z m893 -849 c14 -8 21 -14 15 -14 -5 0 -21 6 -35 14 -14 8 -20 14 -15 14 6 0 21 -6 35 -14z m365 -163 c1027 -460 1845 -795 2346 -963 401 -134 544 -153 764 -104 420 95 1071 354 2329 929 176 80 321 145 322 143 2 -2 -160 -79 -359 -172 -790 -368 -1631 -778 -1927 -940 -116 -63 -283 -165 -316 -193 -48 -41 -72 -101 -103 -262 -68 -349 -116 -1169 -123 -2105 l-1 -220 -8 240 c-39 1222 -121 2026 -232 2269 -29 62 -56 85 -209 173 -260 149 -1366 680 -2467 1185 -278 127 -364 168 -321 155 8 -3 146 -63 305 -135z m5865 48 c-19 -11 -39 -19 -45 -19 -5 0 6 8 25 19 19 11 40 19 45 19 6 0 -6 -8 -25 -19z M3485 6045 c-18 -55 -10 -233 13 -315 73 -262 273 -507 562 -688 164 -103 435 -215 659 -272 416 -106 947 -112 1371 -15 685 157 1170 526 1292 983 23 87 29 270 10 312 l-11 25 0 -30 c-2 -50 -56 -192 -108 -278 -66 -112 -272 -320 -403 -406 -200 -133 -460 -244 -725 -310 -530 -131 -1188 -102 -1662 75 -378 141 -637 315 -809 543 -98 131 -167 276 -177 371 l-3 35 -9 -30z M2772 5847 c-45 -241 45 -562 227 -817 352 -493 1062 -856 1886 -964 766 -101 1547 14 2170 319 457 224 794 543 946 895 79 182 112 383 90 533 -14 93 -31 124 -31 57 0 -93 -96 -307 -207 -463 -85 -120 -252 -288 -383 -386 -839 -630 -2227 -790 -3355 -386 -177 63 -465 206 -610 303 -208 138 -340 260 -474 437 -120 159 -216 351 -228 458 -9 80 -18 84 -31 14z">
                            <Path.Styles>
                                <Style Selector="Path">
                                    <Setter Property="Opacity" Value="0.35" />
                                </Style>
                                <Style Selector="Path[Tag=True]">
                                    <Setter Property="Opacity" Value="1.0" />
                                </Style>
                            </Path.Styles>
                        </Path>
                    </Viewbox>
                </ToggleButton>

                <ToggleButton IsChecked="{Binding IsSoundEnabled, Mode=OneWay}"
                              Command="{Binding ToggleSound}"
                              ToolTip.Tip="Sound">
                    <icons:MaterialIcon Width="24" Height="24"
                                        Tag="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}">
                        <icons:MaterialIcon.Styles>
                            <Style Selector="icons|MaterialIcon[Tag=True]">
                                <Setter Property="Kind" Value="VolumeHigh" />
                            </Style>
                            <Style Selector="icons|MaterialIcon[Tag=False]">
                                <Setter Property="Kind" Value="VolumeOff" />
                            </Style>
                        </icons:MaterialIcon.Styles>
                    </icons:MaterialIcon>
                </ToggleButton>

                <Border Width="34"
                        Height="9"
                        CornerRadius="2"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding FloppyIndicatorTooltip}"
                        Tag="{Binding FloppyIndicatorState}">
                    <Border.Styles>
                        <Style Selector="Border">
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="#2E7D32" />
                            <Setter Property="Background">
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#2B5F35" Offset="0.0" />
                                    <GradientStop Color="#397D45" Offset="0.5" />
                                    <GradientStop Color="#2B5F35" Offset="1.0" />
                                </LinearGradientBrush>
                            </Setter>
                        </Style>
                        <Style Selector="Border[Tag=NoDisk]">
                            <Setter Property="BorderBrush" Value="#7A4B00" />
                            <Setter Property="Background">
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#4A3412" Offset="0.0" />
                                    <GradientStop Color="#76541D" Offset="0.5" />
                                    <GradientStop Color="#4A3412" Offset="1.0" />
                                </LinearGradientBrush>
                            </Setter>
                        </Style>
                        <Style Selector="Border[Tag=Active]">
                            <Setter Property="BorderBrush" Value="#B9FFCD" />
                            <Setter Property="Background">
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#4FAE64" Offset="0.0" />
                                    <GradientStop Color="#9BFFC0" Offset="0.5" />
                                    <GradientStop Color="#4FAE64" Offset="1.0" />
                                </LinearGradientBrush>
                            </Setter>
                            <Setter Property="Effect">
                                <DropShadowEffect Color="#70FF99" BlurRadius="6" OffsetX="0" OffsetY="0" />
                            </Setter>
                        </Style>
                    </Border.Styles>
                </Border>

            </StackPanel>

            <Grid Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0" Background="Black">
                <Image x:Name="AmbientDisplay"
                       Source="{Binding Display}"
                       Margin="-200,0"
                       Stretch="UniformToFill"
                       Opacity="0.6"
                       IsVisible="{Binding Settings.IsAmbientBlurred}">
                    <Image.Effect>
                        <BlurEffect Radius="200" />
                    </Image.Effect>
                </Image>

                <Image x:Name="MainDisplay"
                       IsHitTestVisible="True"
                       Focusable="True"
                       Source="{Binding Display}"
                       PointerEntered="OnDisplayPointerEntered"
                       PointerMoved="OnDisplayPointerMoved"
                       PointerPressed="OnDisplayPointerPressed"
                       PointerReleased="OnDisplayPointerReleased"
                       PointerExited="OnDisplayPointerExited"
                       Stretch="Uniform" />

                <Border Width="16"
                        Height="16"
                        CornerRadius="8"
                        Background="#E53935"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        IsHitTestVisible="False"
                        IsVisible="{Binding IsRecordingIndicatorOn}" />

                <TextBlock Text="{Binding SpeedIndicatorText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           TextAlignment="Right"
                           Margin="0,0,10,8"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="18"
                           Padding="4"
                           FontWeight="SemiBold"
                           IsHitTestVisible="False"
                           IsVisible="{Binding IsSpeedIndicatorVisible}">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#B0000000" BlurRadius="8" OffsetX="0" OffsetY="0" />
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
        </Grid>
    </dialogHostAvalonia:DialogHost>
</Window>
